{
  "name": "ga-lang",
  "version": "1.2.4",
  "description": "An interpreted toy programming language",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "module": "dist/src/index.js",
  "browser": "dist/browser/index.js",
  "bin": {
    "ga": "./bin/ga.js"
  },
  "scripts": {
    "prettier:check": "prettier --check \"./**/*.{js,ts,json}\"",
    "prettier:fix": "prettier --write \"./**/*.{js,ts,json}\"",
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc",
    "build:browser": "esbuild src/index.ts --bundle --format=esm --outfile=dist/browser/index.js --platform=browser",
    "build:all": "pnpm run build && pnpm run build:browser",
    "build:tests": "tsc -p tsconfig.test.json",
    "test": "pnpm run build:all && pnpm run build:tests && node --test ./dist/tests/**/*.js",
    "ga": "pnpm run build && node dist/src/main.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bvsvntv/ga-lang.git"
  },
  "keywords": [
    "devanagari",
    "nepali",
    "nepali-programming-language",
    "programming-language"
  ],
  "author": "Basanta Rai",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bvsvntv/ga-lang/issues"
  },
  "homepage": "https://github.com/bvsvntv/ga-lang#readme",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.x.x",
    "pnpm": ">=10.x.x"
  },
  "exports": {
    "types": "./dist/src/index.d.ts",
    "node": "./dist/src/index.js",
    "browser": "./dist/browser/index.js",
    "default": "./dist/src/index.js"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error"
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "esbuild": "^0.27.3",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
